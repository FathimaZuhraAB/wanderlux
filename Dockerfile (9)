def _site_for_category(cat: Category) -> List[tuple]:
    """Return (site_id, site_name) candidates that plausibly carry this category."""
    GENERAL = [
        ("amazon", "Amazon"), ("flipkart", "Flipkart"), ("meesho", "Meesho"),
        ("snapdeal", "Snapdeal"), ("shopsy", "Shopsy"), ("tatacliq", "Tata CLiQ"),
    ]
    pools = {
        Category.GENERAL:     GENERAL,
        Category.ELECTRONICS: GENERAL + [("reliancedigital", "Reliance Digital"), ("croma", "Croma")],
        Category.FASHION:     GENERAL + [("myntra", "Myntra"), ("ajio", "Ajio"), ("nykaafashion", "Nykaa Fashion")],
        Category.BEAUTY:      GENERAL + [("nykaa", "Nykaa")],
        Category.GROCERY:     [("bigbasket", "BigBasket"), ("blinkit", "Blinkit"), ("zepto", "Zepto"),
                               ("swiggyinstamart", "Instamart"), ("jiomart", "JioMart"), ("amazon", "Amazon")],
        Category.KIDS:        GENERAL + [("firstcry", "FirstCry")],
        Category.PHARMACY:    [("tata1mg", "Tata 1mg"), ("pharmeasy", "PharmEasy"), ("amazon", "Amazon")],
    }
    return pools.get(cat, GENERAL)


def _key(title: str) -> str:
    return hashlib.md5(title.lower().encode()).hexdigest()[:10]


def get_sample_listings(query: str, limit: int = 30) -> List[Listing]:
    """
    Return synthetic-but-plausible listings matching `query`.
    Each call is deterministic for the same query (seeded by the query string)
    so prices don't jitter between requests.
    """
    rng = random.Random(query.lower().strip())
    q = query.lower().strip()

    matches = [p for p in PRODUCT_SEEDS if q in p[0].lower() or any(q in t.lower() for t in p[3])]
    if not matches:
        # broad fallback: pick a few seeds that share any word
        words = set(q.split())
        matches = [p for p in PRODUCT_SEEDS if words & set(p[0].lower().split())]
    if not matches:
        # last resort: show some popular items so UI isn't empty
        matches = rng.sample(PRODUCT_SEEDS, min(4, len(PRODUCT_SEEDS)))

    listings: List[Listing] = []
    for title, base, cat, tags, _emoji in matches:
        sites = _site_for_category(cat)
        n = rng.randint(5, min(len(sites), 9))
        chosen = rng.sample(sites, n)
        for site_id, site_name in chosen:
            variance = (rng.random() - 0.5) * 0.28
            price = max(1, round(base * (1 + variance)))
            mrp = round(base * (1.05 + rng.random() * 0.25))
            listings.append(Listing(
                site_id=site_id,
                site_name=site_name,
                title=title,
                url=f"https://www.{site_id}.com/search?q={query.replace(' ', '+')}",
                price=price,
                mrp=max(price, mrp),
                rating=round(3.5 + rng.random() * 1.4, 1),
                review_count=rng.randint(120, 18400),
                in_stock=rng.random() > 0.08,
                delivery=rng.choice(["Today", "Tomorrow", "2 days", "3-5 days", "10 min", "30 min"]),
                coupon=rng.choice([None, None, "BANK10", "SAVE5", "WELCOME150"]),
                category=cat,
                scraped_at=datetime.utcnow() - timedelta(minutes=rng.randint(0, 30)),
                confidence=0.2,  # mark as sample data
            ))
    return listings[:limit]
