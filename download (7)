"""
BigBasket scraper. Uses their public product-listing JSON endpoint.
"""
from typing import List
import logging
from app.scrapers.base import BaseScraper
from app.models import Listing, Category

logger = logging.getLogger(__name__)


class BigBasketScraper(BaseScraper):
    site_id = "bigbasket"
    site_name = "BigBasket"
    category = Category.GROCERY

    BASE = "https://www.bigbasket.com"
    SEARCH_API = "https://www.bigbasket.com/listing-svc/v2/products"

    async def search(self, query: str, limit: int = 10) -> List[Listing]:
        params = {"type": "ps", "slug": query, "page": 1}
        headers = {
            "Accept": "application/json",
            "X-Channel": "BB-WEB",
            "Referer": f"{self.BASE}/ps/?q={query}",
        }
        r = await self.fetch(self.SEARCH_API, params=params, headers=headers)
        if not r:
            return []
        try:
            data = r.json()
        except Exception:
            return []

        items = []
        products = data.get("tabs", [{}])[0].get("product_info", {}).get("products", [])
        for p in products[:limit]:
            try:
                pricing = p.get("pricing", {}).get("discount", {})
                price = float(pricing.get("prim_price", {}).get("sp") or p.get("pricing", {}).get("discount", {}).get("d_price") or 0)
                mrp = float(pricing.get("prim_price", {}).get("mrp") or 0)
                desc = p.get("desc") or p.get("p_desc") or ""
                if not desc or price <= 0:
                    continue
                images = p.get("images", [])
                img = images[0].get("s") if images else None
                items.append(Listing(
                    site_id=self.site_id,
                    site_name=self.site_name,
                    title=desc,
                    url=f"{self.BASE}{p.get('absolute_url', '')}",
                    image_url=img,
                    price=price,
                    mrp=mrp if mrp >= price else None,
                    in_stock=p.get("availability", {}).get("avail_status", "001") == "001",
                    delivery="Tomorrow",
                    category=Category.GROCERY,
                    confidence=1.0,
                ))
            except (ValueError, KeyError, TypeError) as e:
                logger.debug(f"[bigbasket] skip item: {e}")
                continue
        return items
